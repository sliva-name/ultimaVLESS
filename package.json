{
  "name": "ultima-vless-client",
  "version": "2.1.2",
  "description": "Desktop V2Ray Client for UltimaVPN",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build:renderer": "vite build",
    "build:electron": "npm run typecheck && npm run build:renderer",
    "package:win": "npm run build:electron && electron-builder --win --x64",
    "package:portable": "npm run build:electron && electron-builder --win portable --x64",
    "package:nsis": "npm run build:electron && electron-builder --win nsis --x64",
    "package:all": "npm run build:electron && electron-builder --win nsis portable --x64",
    "build": "npm run package:win",
    "build:portable": "npm run package:portable",
    "build:nsis": "npm run package:nsis",
    "build:all": "npm run package:all",
    "build:only": "npm run build:electron",
    "dist": "npm run build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "electron:start": "electron ."
  },
  "build": {
    "appId": "com.ultima.vless",
    "productName": "UltimaVLESS",
    "copyright": "Copyright © 2024-2026 UltimaVPN",
    "asar": true,
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": [
          "xray.exe",
          "geoip.dat",
          "geosite.dat",
          "wintun.dll",
          "logo.ico",
          "logo.icns",
          "logo-256x256.png",
          "LICENSE"
        ]
      }
    ],
    "win": {
      "forceCodeSigning": false,
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/bin/logo.ico",
      "artifactName": "${productName}-${version}-${arch}-${os}.${ext}",
      "requestedExecutionLevel": "asInvoker"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true,
      "installerIcon": "resources/bin/logo.ico",
      "uninstallerIcon": "resources/bin/logo.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "UltimaVLESS",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "mac": {
      "icon": "resources/bin/logo.icns",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "icon": "resources/bin",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "keywords": [
    "electron",
    "vpn",
    "vless",
    "reality"
  ],
  "author": "UltimaVPN",
  "license": "MIT",
  "devDependencies": {
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "jsdom": "^27.3.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.15.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vitest": "^4.0.15"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "clsx": "^2.0.0",
    "country-flag-icons": "^1.6.4",
    "electron-store": "^8.1.0",
    "js-base64": "^3.7.5",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.1.0"
  }
}
