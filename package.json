{
  "name": "ultima-vless-client",
  "version": "3.4.2",
  "description": "Desktop V2Ray Client for UltimaVPN",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build:renderer": "vite build",
    "build:electron": "npm run typecheck && npm run build:renderer",
    "check:codesign:win": "node -e \"if(!process.env.CSC_LINK||!process.env.CSC_KEY_PASSWORD){console.error('Missing CSC_LINK or CSC_KEY_PASSWORD');process.exit(1)};console.log('Code signing env OK')\"",
    "package:win": "npm run build:electron && electron-builder --win --x64",
    "package:win:signed": "npm run check:codesign:win && npm run build:electron && electron-builder --win --x64",
    "package:portable": "npm run build:electron && electron-builder --win portable --x64",
    "package:nsis": "npm run build:electron && electron-builder --win nsis --x64",
    "package:all": "npm run build:electron && electron-builder --win nsis portable --x64",
    "package:mac": "npm run build:electron && electron-builder --mac --x64 --arm64",
    "package:linux": "npm run build:electron && electron-builder --linux --x64",
    "build": "npm run package:win",
    "build:portable": "npm run package:portable",
    "build:nsis": "npm run package:nsis",
    "build:all": "npm run package:all",
    "build:mac": "npm run package:mac",
    "build:linux": "npm run package:linux",
    "build:only": "npm run build:electron",
    "prepare:xray:win": "node scripts/prepare-xray-assets.mjs --platform win32 --arch x64",
    "prepare:xray:mac": "node scripts/prepare-xray-assets.mjs --platform darwin",
    "prepare:xray:linux": "node scripts/prepare-xray-assets.mjs --platform linux",
    "dist": "npm run build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "verify:yandex": "node scripts/verify-yandex-parse.mjs",
    "verify:release:win": "node scripts/verify-release-config.mjs win",
    "verify:release:linux": "node scripts/verify-release-config.mjs linux",
    "verify:release:mac": "node scripts/verify-release-config.mjs mac",
    "test:run": "vitest run --reporter=dot",
    "verify:ci": "npm run typecheck && npm run test:run",
    "electron:start": "electron .",
    "electron:trace-deprecation": "electron --trace-deprecation ."
  },
  "build": {
    "appId": "com.ultima.vless",
    "productName": "UltimaVLESS",
    "copyright": "Copyright © 2024-2026 UltimaVPN",
    "asar": true,
    "directories": {
      "output": "release/${version}",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": [
          "xray.exe",
          "xray",
          "geoip.dat",
          "geosite.dat",
          "wintun.dll",
          "logo.ico",
          "logo.icns",
          "logo-256x256.png",
          "LICENSE"
        ]
      }
    ],
    "win": {
      "forceCodeSigning": false,
      "signAndEditExecutable": true,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/bin/logo.ico",
      "artifactName": "${productName}-${version}-${arch}-${os}.${ext}",
      "requestedExecutionLevel": "asInvoker"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "selectPerMachineByDefault": false,
      "runAfterFinish": true,
      "license": "installer-license.txt",
      "installerIcon": "resources/bin/logo.ico",
      "uninstallerIcon": "resources/bin/logo.ico",
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "menuCategory": "UltimaVPN",
      "shortcutName": "UltimaVLESS",
      "uninstallDisplayName": "${productName}",
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "warningsAsErrors": false
    },
    "mac": {
      "icon": "resources/bin/logo.icns",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "maintainer": "UltimaVPN antyuhov2@gmail.com",
      "icon": "resources/bin",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  },
  "keywords": [
    "electron",
    "vpn",
    "vless",
    "reality"
  ],
  "author": "UltimaVPN",
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vite-plugin-electron": "^0.29.1",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@sentry/electron": "^7.10.0",
    "clsx": "^2.1.1",
    "country-flag-icons": "^1.6.15",
    "electron-store": "^11.0.2",
    "js-base64": "^3.7.8",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0"
  }
}
