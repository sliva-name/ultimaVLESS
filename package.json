{
  "name": "ultima-vless-client",
  "version": "1.3.6",
  "description": "Desktop V2Ray Client for UltimaVPN",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "dist": "npm run build && electron-builder",
    "electron:start": "electron ."
  },
  "build": {
    "appId": "com.ultima.vless",
    "productName": "UltimaVLESS",
    "directories": {
      "output": "release/${version}"
    },
    "files": [
      "dist",
      "dist-electron",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/bin/logo.ico",
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "mac": {
      "icon": "resources/bin/logo.icns",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "icon": "resources/bin",
      "target": [
        "AppImage",
        "deb"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true,
      "installerIcon": "resources/bin/logo.ico",
      "uninstallerIcon": "resources/bin/logo.ico"
    }
  },
  "keywords": [
    "electron",
    "vpn",
    "vless",
    "reality"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "jsdom": "^27.3.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.15.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vitest": "^4.0.15"
  },
  "dependencies": {
    "autoprefixer": "^10.4.0",
    "axios": "^1.6.0",
    "clsx": "^2.0.0",
    "country-flag-icons": "^1.6.4",
    "electron-store": "^8.1.0",
    "js-base64": "^3.7.5",
    "lucide-react": "^0.294.0",
    "postcss": "^8.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.1.0",
    "tailwindcss": "^3.3.0"
  }
}
